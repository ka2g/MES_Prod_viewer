# ---------- outdoor-relay 설정 (exe와 같은 폴더) ----------
# Win7: outdoor-relay.env 로 저장 (탐색기에서 .env 이름 변경 불가)
# node: relay/.env 또는 relay/outdoor-relay.env

# 안산시 원시동 근처 좌표 (Open-Meteo)
OUTDOOR_LAT=37.3169
OUTDOOR_LON=126.8258
OUTDOOR_LOCATION=안산시 원시동

# Pull: MES 서버(240)가 GET http://10.201.219.119:8080/weather
RELAY_HOST=0.0.0.0
RELAY_PORT=8080
RELAY_REFRESH_MS=600000
RELAY_HTTP=1
RELAY_PUSH=1

# Push: MES 서버로 POST (아웃바운드 막힌 240은 수신만)
MES_PUSH_URL=http://10.201.219.240:3000/api/env/outdoor
# MES .env 의 ENV_OUTDOOR_INGEST_KEY 와 동일 (비우면 MES에서 검증 생략)
OUTDOOR_INGEST_KEY=change-me-outdoor-key
