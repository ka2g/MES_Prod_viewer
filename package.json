{
  "name": "mes-prod-viewer",
  "version": "1.0.0",
  "private": true,
  "description": "KH_MES 생산라인 모니터링 시스템 (Node)",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "relay:outdoor": "node relay/outdoor-relay.js",
    "build:exe": "pkg . -t node18-win-x64 --out-path dist",
    "build:relay-exe": "pkg relay/outdoor-relay.js --config relay/pkg.json -o dist/outdoor-relay.exe && npm run stage:relay",
    "stage:relay": "powershell -NoProfile -Command \"Copy-Item relay/start-outdoor-relay-hidden.vbs,relay/start-outdoor-relay-tray.ps1 dist/ -Force; Copy-Item relay/.env.example dist/outdoor-relay.env.example -Force\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": [
      "server.js",
      "mesRepository.js",
      "lineActivity.js",
      "envStore.js",
      "alarmStore.js",
      "notifier.js",
      "outdoorStore.js"
    ],
    "assets": [
      "public/**/*",
      "images/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  }
}
