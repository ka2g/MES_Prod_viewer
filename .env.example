# SQL Server
MSSQL_SERVER=10.201.216.110
MSSQL_DATABASE=KH_MES
MSSQL_USER=your_user
MSSQL_PASSWORD=your_password
# 레거시 SQL Server(예: 2014)는 Node(OpenSSL)와 TLS 버전 불일치가 나면 false 사용
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true


# MSSQL 새 인스턴스(TLS 1.2+)면 true 가능
# HTTP — 0.0.0.0이면 같은 네트워크의 다른 PC에서 (이 PC IP):PORT 로 접속 가능
HOST=0.0.0.0
PORT=3000
MES_REFRESH_MS=8000

# 최근 N일까지의 계획에서 라인별 최신 행 (당일 우선 포함)
MES_PLAN_LOOKBACK_DAYS=14
# ASSY 전용 plan_date 깊이(일). 미설정 시 공통 LOOKBACK 과 7일 중 더 작은 값(과거 ACTIVE=Y 노출 완화).
# 장기 진행 라인까지 보려면 예: MES_ASSY_PLAN_LOOKBACK_DAYS=30
MES_ASSY_PLAN_LOOKBACK_DAYS=

# ---------- SMT 생산실 온·습도 (ESP32 + SHT45 I2C) ----------
# ESP32 POST /api/env/ingest 헤더 X-Device-Key 와 동일 (비우면 키 검증 생략)
ENV_INGEST_KEY=change-me-env-key
ENV_DEVICE_ID=SMT_SHT-01
ENV_REFRESH_MS=15000
ENV_HISTORY_HOURS=24
ENV_HISTORY_BUCKET_MIN=10
ENV_RETENTION_DAYS=90
# 온습도 설정 메뉴 PIN (기본 smt1234)
ENV_SETTINGS_PIN=smt1234

# ---------- 온·습도 한계값(쾌적 구간) ----------
# 이 범위를 벗어나면 경보 후보. 프런트 차트 한계선·게이지 경보색에도 사용
ENV_TEMP_MIN=22
ENV_TEMP_MAX=28
ENV_HUM_MIN=40
ENV_HUM_MAX=60

# ---------- 알람 ----------
# 순간 스파이크 무시: 이 시간(분) 이상 연속 이탈해야 경보 발생
ENV_ALARM_SUSTAIN_MIN=3
# 센서 수신 지연 표시(분) / 단절 경보(분) — 2단계
ENV_STALE_WARN_MIN=5
ENV_STALE_ALARM_MIN=15

# ---------- 외부 통지 (선택, 비우면 비활성) ----------
# 서버 PC에서 외부망 접속이 가능해야 동작합니다.
# 알람 발생/해제 시 JSON POST 되는 범용 webhook (Slack/Teams 수신 URL 등)
ENV_ALARM_WEBHOOK_URL=
# Telegram 봇 통지 (둘 다 설정해야 동작)
ENV_TELEGRAM_BOT_TOKEN=
ENV_TELEGRAM_CHAT_ID=
